<Application x:Class="BroadcastControl.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF14100D" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF1C1713" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF4C3C2F" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FFEB9B52" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFFFC977" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF96D39A" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFD5C2AF" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF15110E" />
            <SolidColorBrush x:Key="OverlayPanelBrush" Color="#D9231B15" />
            <SolidColorBrush x:Key="DrawerBrush" Color="#FF18130F" />
            <SolidColorBrush x:Key="DrawerBorderBrush" Color="#FF4C3C2F" />
            <SolidColorBrush x:Key="DrawerTextBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="DrawerItemBrush" Color="#FF241D16" />
            <SolidColorBrush x:Key="DrawerItemBorderBrush" Color="#FF5D4937" />
            <SolidColorBrush x:Key="TopBarButtonBrush" Color="#FF2A2018" />
            <SolidColorBrush x:Key="TopBarButtonHoverBrush" Color="#FF36281E" />
            <SolidColorBrush x:Key="TopBarButtonPressedBrush" Color="#FF443124" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
