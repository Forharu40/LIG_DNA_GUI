<Application x:Class="BroadcastControl.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E2024" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF2B2E34" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF474B53" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF5F7BEA" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFD6AD52" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF86C595" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF2F4F7" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFB8BDC6" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FF181A1F" />
            <SolidColorBrush x:Key="OverlayPanelBrush" Color="#D926292E" />
            <SolidColorBrush x:Key="DrawerBrush" Color="#FF26292F" />
            <SolidColorBrush x:Key="DrawerBorderBrush" Color="#FF454A53" />
            <SolidColorBrush x:Key="DrawerTextBrush" Color="#FFF2F4F7" />
            <SolidColorBrush x:Key="DrawerItemBrush" Color="#FF31353C" />
            <SolidColorBrush x:Key="DrawerItemBorderBrush" Color="#FF4E535C" />
            <SolidColorBrush x:Key="TopBarButtonBrush" Color="#FF3A3E46" />
            <SolidColorBrush x:Key="TopBarButtonHoverBrush" Color="#FF474C55" />
            <SolidColorBrush x:Key="TopBarButtonPressedBrush" Color="#FF565B65" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
