<Application x:Class="BroadcastControl.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Teal"
                                             SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF2B2E33" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF3A3D43" />
            <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF565A61" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF5F7BEA" />
            <SolidColorBrush x:Key="DangerBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFD6AD52" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#FF86C595" />
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF4F5F7" />
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FFC5C9D1" />
            <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFE6E0D6" />
            <SolidColorBrush x:Key="OverlayPanelBrush" Color="#D932353A" />
            <SolidColorBrush x:Key="DrawerBrush" Color="#FF34373D" />
            <SolidColorBrush x:Key="DrawerBorderBrush" Color="#FF5A5E66" />
            <SolidColorBrush x:Key="DrawerTextBrush" Color="#FFF4F5F7" />
            <SolidColorBrush x:Key="DrawerItemBrush" Color="#FF3C4047" />
            <SolidColorBrush x:Key="DrawerItemBorderBrush" Color="#FF61656D" />
            <SolidColorBrush x:Key="TopBarButtonBrush" Color="#FF484C53" />
            <SolidColorBrush x:Key="TopBarButtonHoverBrush" Color="#FF565B63" />
            <SolidColorBrush x:Key="TopBarButtonPressedBrush" Color="#FF656A73" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
