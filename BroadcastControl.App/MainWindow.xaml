<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LIG DNA GUI"
        Width="1680"
        Height="960"
        MinWidth="1380"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D1117">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- 상단 듀얼 화면: 좌측 큰 화면 3/4, 중앙 스왑 버튼, 우측 작은 화면 1/4 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="82" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 큰 화면: 현재는 EO 노트북 카메라 영상을 출력한다 -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ClipToBounds="True">
                    <!-- 전자 줌은 좌측 큰 화면에만 적용한다 -->
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                        ScaleY="{Binding LargeFeedScale}" />
                    </Grid.RenderTransform>

                    <Rectangle Fill="#FF111821" />

                    <!-- 실제 카메라 프레임 -->
                    <Image Source="{Binding PrimaryFeedImage}"
                           Stretch="UniformToFill" />

                    <!-- 카메라가 아직 없거나 EO가 작은 화면으로 내려간 경우를 대비한 배경 -->
                    <Rectangle Margin="16"
                               Fill="#10161F2A"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />

                    <!-- 화면 좌측 상단에 어떤 피드인지 제목을 표시 -->
                    <Border Margin="18"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding LargeFeedTitle}" />
                    </Border>

                    <!-- 화면 하단에는 현재 피드 설명을 보여준다 -->
                    <TextBlock Margin="18,0,18,18"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="16"
                               Text="{Binding LargeFeedSubtitle}" />

                    <!-- 향후 detector / tracker 결과를 그릴 오버레이 레이어 -->
                    <ItemsControl ItemsSource="{Binding PrimaryOverlays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding Width}"
                                      Height="{Binding Height}">
                                    <!-- 요청한 형태대로 채움 없는 빨간 테두리 박스를 사용한다 -->
                                    <Border BorderBrush="#FFFF3B3B"
                                            BorderThickness="2"
                                            Background="Transparent"
                                            CornerRadius="2" />
                                    <!-- 박스 바로 옆에 빨간 텍스트 라벨을 붙인다 -->
                                    <TextBlock Margin="6,-24,0,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Foreground="#FFFF3B3B"
                                               FontWeight="SemiBold"
                                               Text="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Margin="0,0,18,18"
                            Padding="12,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#3318C6B0"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding ElectronicZoomStatus}" />
                    </Border>
                </Grid>
            </Border>

            <!-- 중앙 스왑 버튼 -->
            <Grid Grid.Column="1">
                <Button Width="62"
                        Height="90"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Command="{Binding SwapFeedsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        FontSize="22"
                        FontWeight="Bold"
                        Content="↔" />
            </Grid>

            <!-- 우측 작은 화면: 현재는 IR 자리 표시 영역 -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ClipToBounds="True">
                    <Rectangle Fill="#FF151920" />

                    <!-- EO가 작은 화면으로 내려가는 경우 이 영역에도 EO 카메라를 표시할 수 있다 -->
                    <Image Source="{Binding SecondaryFeedImage}"
                           Stretch="UniformToFill" />

                    <Rectangle Margin="16"
                               Fill="#10161F2A"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />

                    <Border Margin="18"
                            Padding="8,5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding SmallFeedTitle}" />
                    </Border>

                    <TextBlock Margin="18,0,18,18"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Text="{Binding SmallFeedSubtitle}" />

                    <!-- 작은 화면에도 향후 탐지 오버레이를 동일한 방식으로 얹을 수 있다 -->
                    <ItemsControl ItemsSource="{Binding SecondaryOverlays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Width="{Binding Width}"
                                      Height="{Binding Height}">
                                    <Border BorderBrush="#FFFF3B3B"
                                            BorderThickness="2"
                                            Background="Transparent"
                                            CornerRadius="2" />
                                    <TextBlock Margin="6,-22,0,0"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               Foreground="#FFFF3B3B"
                                               FontWeight="SemiBold"
                                               Text="{Binding Label}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 3분할: VLM 결과, 시스템 로그, 기능 제어 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측: VLM 결과 출력창 -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="VLM 결과값 출력창" />
                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding VlmResults}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Width="82"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Text="{Binding Time}" />
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                                       Text="{Binding Category}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Message}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 중앙: 실시간 시스템 로그 -->
            <Border Grid.Column="1"
                    Margin="12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="실시간 시스템 로그" />

                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding SystemLogs}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Width="82"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Text="{Binding Time}" />
                                            <TextBlock Foreground="#FF8AB4FF"
                                                       Text="{Binding Category}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Message}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 우측: 기능 제어 버튼 -->
            <Border Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="기능 제어" />

                    <!-- 버튼은 세로 크기를 키워 어떤 버튼인지 한눈에 읽히도록 설계했다 -->
                    <Button Grid.Row="1"
                            Margin="0,14,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding CycleModeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="{Binding CurrentMode}" />

                    <Button Grid.Row="2"
                            Margin="0,12,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding CycleDetectionCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="{Binding CurrentDetectionProfile}" />

                    <Button Grid.Row="3"
                            Margin="0,12,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="{Binding PowerStatus}" />

                    <Button Grid.Row="4"
                            Margin="0,12,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding ToggleElectronicZoomCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="전자 Zoom" />

                    <UniformGrid Grid.Row="5"
                                 Margin="0,12,0,0"
                                 Columns="2">
                        <Button Margin="0,0,8,0"
                                MinHeight="54"
                                Padding="12"
                                Command="{Binding IncreaseZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Content="Zoom +" />
                        <Button Margin="8,0,0,0"
                                MinHeight="54"
                                Padding="12"
                                Command="{Binding DecreaseZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Content="Zoom -" />
                    </UniformGrid>

                    <Button Grid.Row="6"
                            Margin="0,12,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding ToggleMotorCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="{Binding MotorStatus}" />

                    <Button Grid.Row="7"
                            Margin="0,12,0,0"
                            MinHeight="60"
                            Padding="16"
                            Command="{Binding ToggleTrackingCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Content="{Binding TrackingStatus}" />

                    <Grid Grid.Row="8"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="12"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="White"
                                           Text="밝기" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding BrightnessText}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="12"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="White"
                                           Text="대조비" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding ContrastText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ItemsControl Grid.Row="9"
                                  Margin="0,14,0,0"
                                  ItemsSource="{Binding FeatureSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock Foreground="White"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#FFD3DDE8"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
