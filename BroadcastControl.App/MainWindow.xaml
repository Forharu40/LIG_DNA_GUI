<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="LIG DNA GUI"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DropShadowEffect x:Key="SoftPanelShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="TopBarShadow"
                          BlurRadius="6"
                          ShadowDepth="0"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="DrawerShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.10"
                          Color="#66000000" />

        <Style x:Key="GlassCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Effect" Value="{StaticResource SoftPanelShadow}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="OverlayCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style x:Key="TopBarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarSmallButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarCompactSlider" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ArrowButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SettingsActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawerItemBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="ZoomSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <!-- 전체 창 최상위 컨테이너임.
             상단 툴바, 본문 패널, 설정 드로어를 이 Grid 안에 배치 -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="66" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="2"
                       Margin="-4"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <DynamicResource ResourceKey="WindowBackdropBrush" />
                </Rectangle.Fill>
            </Rectangle>

            <!-- 상단 툴바:
                 전원 종료, 녹화 상태, 밝기/대조비, 모드 전환, 설정 버튼 배치 -->
            <Border Grid.Row="0"
                    Style="{StaticResource GlassCardBorder}"
                    CornerRadius="2"
                    Effect="{StaticResource TopBarShadow}">
                <Grid Margin="14,10,42,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="152" />
                        <ColumnDefinition Width="152" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            MinWidth="126"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource TopBarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="16"
                                     Height="16"
                                     Margin="0,0,8,0"
                                     Fill="{Binding CurrentThreatBrush}" />
                            <TextBlock Text="{Binding PowerButtonText}" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Opacity="{Binding RecordingIndicatorOpacity}">
                        <Ellipse Width="12"
                                 Height="12"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding RecordingIndicatorBrush}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RecordingTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="영상 녹화 중" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <Button HorizontalAlignment="Left"
                                Command="{Binding ResetBrightnessCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding BrightnessText}" />
                        <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center">
                        <Button HorizontalAlignment="Left"
                                Command="{Binding ResetContrastCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding ContrastText}" />
                        <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="자동"
                            IsHitTestVisible="{Binding CanSelectAutoMode}"
                            Opacity="{Binding AutoModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="자동" />

                    <Button Grid.Column="5"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="수동"
                            IsHitTestVisible="{Binding CanSelectManualMode}"
                            Opacity="{Binding ManualModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="수동" />

                    <Button Grid.Column="6"
                            Width="84"
                            Margin="0,0,12,0"
                            Padding="10,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Style="{StaticResource TopBarSmallButton}"
                            Opacity="{Binding ManualRecordingButtonOpacity}"
                            IsEnabled="{Binding IsManualMode}"
                            Command="{Binding ToggleManualRecordingCommand}"
                            Content="{Binding ManualRecordingButtonText}" />

                    <Button Grid.Column="7"
                            Width="54"
                            Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource TopBarButton}">
                        <materialDesign:PackIcon Kind="Menu"
                                                 Width="24"
                                                 Height="24" />
                    </Button>
                </Grid>
            </Border>

            <!-- 본문 영역:
                 왼쪽 카메라 화면, 오른쪽 시스템 현황/상황 분석/시스템 로그 패널 -->
            <Grid Grid.Row="1"
                  Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.4*" />
                    <ColumnDefinition Width="1.02*" />
                </Grid.ColumnDefinitions>

                <!-- 카메라 패널:
                     EO 주 화면, IR 인셋 화면, 모터 조작 버튼, 전자 줌 UI를 포함함. -->
                <Border x:Name="CameraPanel"
                        Grid.Column="0"
                        Margin="0,0,12,0"
                        Style="{StaticResource GlassCardBorder}"
                        BorderBrush="#00000000"
                        CornerRadius="2">
                    <Grid x:Name="CameraViewport"
                          ClipToBounds="True"
                          SizeChanged="CameraViewport_OnSizeChanged"
                          MouseLeftButtonDown="CameraViewport_OnMouseLeftButtonDown"
                          MouseWheel="CameraViewport_OnMouseWheel"
                          MouseMove="CameraViewport_OnMouseMove"
                          MouseLeftButtonUp="CameraViewport_OnMouseLeftButtonUp">
                        <Rectangle Fill="{DynamicResource SurfaceAltBrush}" />

                        <!-- LargeFeedImage는 크게 보여줄 카메라 영상 바인딩임.
                             EO/IR 스왑 상태에 따라 표시 영상이 달라짐. -->
                        <Image Source="{Binding LargeFeedImage}"
                               Margin="0"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                                    ScaleY="{Binding LargeFeedScale}" />
                                    <TranslateTransform X="{Binding ZoomTransformX}"
                                                        Y="{Binding ZoomTransformY}" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>

                        <!-- 좌상단 라벨은 현재 큰 화면의 카메라 종류 표시임. -->
                        <Border Margin="16,12,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Style="{StaticResource OverlayCardBorder}"
                                BorderThickness="0"
                                CornerRadius="2"
                                Padding="8,4">
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Text="{Binding LargeFeedTitle}" />
                        </Border>

                        <!-- 전자 줌 미니맵:
                             확대 중 전체 화면 대비 현재 보고 있는 영역을 작은 지도처럼 표시함. -->
                        <Border Width="152"
                                Height="108"
                                Margin="18,0,0,20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource OverlayCardBorder}"
                                CornerRadius="2"
                                Visibility="{Binding ShowZoomMiniMap, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="10">
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Text="Zoom 미니맵" />
                                <Canvas Width="130"
                                        Height="74"
                                        Margin="0,18,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                    <Rectangle Width="130"
                                               Height="74"
                                               Fill="#55333F4D"
                                               Stroke="#FF64748B"
                                               StrokeThickness="1" />
                                    <Rectangle Width="{Binding MiniMapViewportWidth}"
                                               Height="{Binding MiniMapViewportHeight}"
                                               Canvas.Left="{Binding MiniMapViewportLeft}"
                                               Canvas.Top="{Binding MiniMapViewportTop}"
                                               Fill="#3300FFAA"
                                               Stroke="{DynamicResource AccentBrush}"
                                               StrokeThickness="1.5" />
                                </Canvas>
                            </Grid>
                        </Border>

                        <Canvas IsHitTestVisible="False" />

                        <!-- IR/EO 인셋 화면:
                             작은 화면 클릭 시 큰 화면과 스왑되는 입력 영역임. -->
                        <Button Width="168"
                                Height="126"
                                Margin="0,8,26,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Command="{Binding SwapFeedsCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <!-- IR 인셋은 영상만 보이도록 내부 배경과 테두리를 제거함. -->
                            <Border Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="1">
                                <Grid ClipToBounds="True">
                                    <Image Source="{Binding InsetFeedImage}"
                                           Stretch="UniformToFill" />
                                    <Border Margin="10,10,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Top"
                                             Style="{StaticResource OverlayCardBorder}"
                                             BorderThickness="0"
                                             CornerRadius="2"
                                             Padding="7,3">
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Text="{Binding InsetFeedTitle}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- 모터 방향 버튼:
                             수동 모드에서만 표시되며 이후 실제 모터 제어 명령과 연결할 위치임. -->
                        <Grid Margin="0,0,24,26"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Visibility="{Binding IsManualMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Command="{Binding MoveMotorCommand}"
                                    CommandParameter="Up"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    Style="{StaticResource ArrowButton}">
                                <materialDesign:PackIcon Kind="ArrowUpBold" Width="20" Height="20" />
                            </Button>
                            <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,6,6,6"
                                    Command="{Binding MoveMotorCommand}"
                                    CommandParameter="Left"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    Style="{StaticResource ArrowButton}">
                                <materialDesign:PackIcon Kind="ArrowLeftBold" Width="20" Height="20" />
                            </Button>
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="6,6,0,6"
                                    Command="{Binding MoveMotorCommand}"
                                    CommandParameter="Right"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    Style="{StaticResource ArrowButton}">
                                <materialDesign:PackIcon Kind="ArrowRightBold" Width="20" Height="20" />
                            </Button>
                            <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Command="{Binding MoveMotorCommand}"
                                    CommandParameter="Down"
                                    IsEnabled="{Binding CanUseMotorControls}"
                                    Style="{StaticResource ArrowButton}">
                                <materialDesign:PackIcon Kind="ArrowDownBold" Width="20" Height="20" />
                            </Button>
                        </Grid>

                        <!-- 전자 줌 패널은 배경이 과하게 길어 보이지 않도록 고정 폭으로 묶음. -->
                        <!-- 전자 줌 패널:
                             줌 리셋 버튼, 배율 슬라이더, 현재 배율 텍스트를 한 묶음으로 표시함. -->
                        <Border Margin="182,0,220,18"
                                Padding="10,7"
                                Width="340"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource OverlayCardBorder}"
                                CornerRadius="2"
                                Visibility="{Binding IsManualMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- 전자 줌 라벨은 작은 리셋 버튼임. 클릭 시 x1.0 기본 배율로 복귀함. -->
                                <Button VerticalAlignment="Center"
                                        Command="{Binding ResetZoomCommand}"
                                        Style="{StaticResource TopBarSmallButton}"
                                        Content="전자 ZOOM" />
                                <Slider Grid.Column="1"
                                        Margin="12,0"
                                        Minimum="1"
                                        Maximum="4"
                                        TickFrequency="0.1"
                                        IsSnapToTickEnabled="False"
                                        Value="{Binding ZoomLevel, UpdateSourceTrigger=PropertyChanged}"
                                        IsEnabled="{Binding CanUseZoomControls}"
                                        Style="{StaticResource ZoomSliderStyle}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="13"
                                           Text="{Binding ZoomLevelText}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 우측 정보 패널:
                     시스템 현황, 상황 분석, 시스템 로그를 세로로 배치함. -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.68*" />
                        <RowDefinition Height="1.44*" />
                        <RowDefinition Height="1.56*" />
                    </Grid.RowDefinitions>

                    <!-- 시스템 현황 패널:
                         위험 등급과 주 탐지체처럼 즉시 필요한 상태만 표시함. -->
                    <Border Grid.Row="0"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,12,18,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource PanelTitle}" Text="시스템 현황" />
                            <StackPanel Margin="0,10,0,5"
                                        Orientation="Horizontal">
                                <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Text="{Binding CurrentThreatText}" />                
                                <Ellipse Width="14"
                                        Height="14"
                                        Margin="5,5,10,0"
                                        VerticalAlignment="Top"
                                        Fill="{Binding CurrentThreatBrush}" />

                            </StackPanel>
                            <TextBlock Margin="0,5,0,5"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"
                                       Text="{Binding PrimaryTargetText}" />
                        </StackPanel>
                    </Border>

                    <!-- 상황 분석 패널:
                         향후 VLM 분석 문장을 실시간으로 누적 표시할 영역임. -->
                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,14,18,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource PanelTitle}" Text="상황 분석" />
                            <ListBox Grid.Row="1"
                                     Margin="0,10,0,0"
                                     ItemsSource="{Binding AnalysisItems}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="{DynamicResource DrawerItemBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource WarningBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Time}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="14"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <!-- 시스템 로그 패널:
                         중요한 모드 변경, 저장, 경고 이벤트만 남기는 운영 로그 영역임. -->
                    <Border Grid.Row="2"
                            Style="{StaticResource GlassCardBorder}"
                            CornerRadius="2"
                            Padding="18,14,18,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource PanelTitle}" Text="시스템 로그" />
                                <Button Grid.Column="1"
                                        Padding="10,4"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TopBarSmallButton}"
                                        Command="{Binding SaveSystemLogsCommand}"
                                        Content="저장" />
                            </Grid>
                            <ListBox Grid.Row="1"
                                     Margin="0,10,0,0"
                                     ItemsSource="{Binding SystemLogs}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="{DynamicResource DrawerItemBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="1">
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource WarningBrush}"
                                                           FontSize="11"
                                                           Text="{Binding Time}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           FontSize="14"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- SettingsBackdrop은 설정창 뒤 배경을 어둡게 깔고 바깥 클릭 시 닫는 오버레이임. -->
        <Rectangle x:Name="SettingsBackdrop"
                   Fill="#22000000"
                   Opacity="0"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   Panel.ZIndex="20"
                   MouseLeftButtonDown="SettingsBackdrop_OnMouseLeftButtonDown" />

        <!-- 설정 드로어:
             우측 슬라이드 패널이며 주 탐지체와 테마 변경 기능을 담음. -->
        <Border x:Name="SettingsDrawer"
                Width="280"
                Margin="0,12,12,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Background="{DynamicResource DrawerBrush}"
                BorderBrush="{DynamicResource DrawerBorderBrush}"
                BorderThickness="1"
                Padding="22"
                Effect="{StaticResource DrawerShadow}"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"
                Opacity="0"
                Visibility="Collapsed"
                Panel.ZIndex="21">
            <Border.RenderTransform>
                <!-- 기본 위치는 화면 오른쪽 바깥임. 열릴 때 안쪽으로 부드럽게 이동함. -->
                <TranslateTransform x:Name="SettingsDrawerTransform" X="320" />
            </Border.RenderTransform>
            <Border.CacheMode>
                <BitmapCache RenderAtScale="1" />
            </Border.CacheMode>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="설정창"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource DrawerTextBrush}" />

                <Border Grid.Row="1"
                        Margin="0,18,0,14"
                        BorderBrush="{DynamicResource DrawerBorderBrush}"
                        BorderThickness="0,0,0,3">
                    <TextBlock Margin="0,0,0,10"
                               Text="주 탐지체 변경"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DrawerTextBrush}" />
                </Border>

                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding PrimaryTargets}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,10"
                                    Command="{Binding DataContext.SelectPrimaryTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SettingsActionButton}"
                                    Content="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="3"
                        Margin="0,8,0,12"
                        BorderBrush="{DynamicResource DrawerBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock Margin="0,12,0,0"
                               Text="테마 변경"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DrawerTextBrush}" />
                </Border>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Margin="0,0,8,0"
                            Command="{Binding SetThemeCommand}"
                            CommandParameter="Dark"
                            Opacity="{Binding DarkThemeButtonOpacity}"
                            Style="{StaticResource SettingsActionButton}"
                            Content="어두운 테마" />
                    <Button Grid.Column="1"
                            Command="{Binding SetThemeCommand}"
                            CommandParameter="Light"
                            Opacity="{Binding LightThemeButtonOpacity}"
                            Style="{StaticResource SettingsActionButton}"
                            Content="밝은 테마" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
