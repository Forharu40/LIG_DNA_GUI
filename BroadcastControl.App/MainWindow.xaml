<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LIG DNA GUI"
        Width="1680"
        Height="960"
        MinWidth="1380"
        MinHeight="820"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D1117">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 상단 헤더 -->
        <Border Grid.Row="0"
                Padding="18"
                Margin="0,0,0,16"
                Background="#FF101722"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding MissionTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF9FB1C5"
                               Text="{Binding HeaderSummary}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Padding="12,6"
                            Margin="0,0,10,0"
                            Background="#2618C6B0"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding CurrentMode}" />
                    </Border>
                    <Border Padding="12,6"
                            Margin="0,0,10,0"
                            Background="#22FFC145"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource WarningBrush}"
                                   Text="{Binding CurrentDetectionProfile}" />
                    </Border>
                    <Border Padding="12,6"
                            Background="#22FFFFFF"
                            CornerRadius="999">
                        <TextBlock Foreground="White"
                                   Text="{Binding PowerStatus}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 상단 화면 영역: 좌측 3/4, 우측 1/4, 중앙 스왑 버튼 -->
        <Grid Grid.Row="1"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="74" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 큰 화면 -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ClipToBounds="True">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                        ScaleY="{Binding LargeFeedScale}" />
                    </Grid.RenderTransform>

                    <Rectangle Margin="16"
                               Fill="#FF131A24"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />
                    <Line X1="80"
                          Y1="65"
                          X2="900"
                          Y2="455"
                          Stroke="#12FFFFFF"
                          StrokeThickness="1" />
                    <Line X1="110"
                          Y1="425"
                          X2="840"
                          Y2="108"
                          Stroke="#10FFFFFF"
                          StrokeThickness="1" />
                    <Border Margin="20"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding LargeFeedTitle}" />
                    </Border>
                    <TextBlock Margin="20,0,20,20"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="16"
                               Text="{Binding LargeFeedSubtitle}" />
                    <Border Width="140"
                            Height="82"
                            Margin="620,132,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            BorderBrush="#FFE44343"
                            BorderThickness="2"
                            Background="#11E44343"
                            CornerRadius="4" />
                    <Border Width="112"
                            Height="68"
                            Margin="420,220,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            BorderBrush="#FFE44343"
                            BorderThickness="2"
                            Background="#11E44343"
                            CornerRadius="4" />
                    <Border Width="126"
                            Height="74"
                            Margin="290,146,0,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            BorderBrush="#FFE44343"
                            BorderThickness="2"
                            Background="#11E44343"
                            CornerRadius="4" />
                    <Border Margin="0,0,20,20"
                            Padding="12,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#3318C6B0"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding ElectronicZoomStatus}" />
                    </Border>
                </Grid>
            </Border>

            <!-- 중앙 화면 스왑 버튼 -->
            <Grid Grid.Column="1">
                <Button Width="58"
                        Height="58"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Command="{Binding SwapFeedsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Content="↔" />
            </Grid>

            <!-- 우측 작은 화면 -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Rectangle Margin="16"
                               Fill="#FF151920"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />
                    <Border Margin="20"
                            Padding="8,5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding SmallFeedTitle}" />
                    </Border>
                    <Ellipse Width="54"
                             Height="54"
                             Margin="0,0,30,30"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Fill="#26FFFFFF"
                             Stroke="#40FFFFFF" />
                    <TextBlock Margin="20,0,20,20"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Text="{Binding SmallFeedSubtitle}" />
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 영역: 1/3 VLM 결과, 1/3 명령 입력, 1/3 기능 버튼 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측: VLM 결과 출력창 -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="VLM 결과값 출력창" />
                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding VlmResults}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Width="82"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Text="{Binding Time}" />
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                                       Text="{Binding Category}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Message}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 중앙: 명령 입력창 -->
            <Border Grid.Column="1"
                    Margin="12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="명령 입력창" />

                    <TextBlock Grid.Row="1"
                               Margin="0,10,0,0"
                               Foreground="#FFB8C6D5"
                               Text="예시: FW-01 경로 요약 / EO 확대 / IR 우선 보기 / 탐지 모드 변경" />

                    <TextBox Grid.Row="2"
                             Margin="0,14,0,14"
                             Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="14"
                             Background="#FF121923"
                             Foreground="White"
                             BorderBrush="#FF2B3441"
                             BorderThickness="1"
                             FontSize="16" />

                    <Grid Grid.Row="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding LastCommandResult}" />
                        <UniformGrid Grid.Row="1"
                                     Margin="0,12,0,0"
                                     Columns="2">
                            <Button Margin="0,0,10,0"
                                    Padding="12"
                                    Command="{Binding SendCommandInputCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Content="명령 전송" />
                            <Button Padding="12"
                                    Command="{Binding ClearCommandInputCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="입력 초기화" />
                        </UniformGrid>
                    </Grid>
                </Grid>
            </Border>

            <!-- 우측: 기능 제어 버튼과 상태 -->
            <Border Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="기능 제어" />

                    <UniformGrid Grid.Row="1"
                                 Margin="0,14,0,0"
                                 Columns="2">
                        <Button Margin="0,0,10,10"
                                Padding="12"
                                Command="{Binding CycleModeCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="모드" />
                        <Button Margin="0,0,0,10"
                                Padding="12"
                                Command="{Binding CycleDetectionCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="탐지" />
                        <Button Margin="0,0,10,10"
                                Padding="12"
                                Command="{Binding TogglePowerCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="On / Off" />
                        <Button Margin="0,0,0,10"
                                Padding="12"
                                Command="{Binding ToggleElectronicZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="전자 zoom" />
                        <Button Margin="0,0,10,10"
                                Padding="12"
                                Command="{Binding ToggleMotorCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="motor" />
                        <Button Margin="0,0,0,10"
                                Padding="12"
                                Command="{Binding ToggleTrackingCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="tracking" />
                    </UniformGrid>

                    <UniformGrid Grid.Row="2"
                                 Margin="0,4,0,0"
                                 Columns="2">
                        <Button Margin="0,0,10,10"
                                Padding="12"
                                Command="{Binding IncreaseZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="zoom +" />
                        <Button Margin="0,0,0,10"
                                Padding="12"
                                Command="{Binding DecreaseZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="zoom -" />
                    </UniformGrid>

                    <Border Grid.Row="3"
                            Margin="0,6,0,0"
                            Padding="12"
                            Background="#FF121923"
                            BorderBrush="#FF27303C"
                            BorderThickness="1"
                            CornerRadius="12">
                        <WrapPanel>
                            <TextBlock Margin="0,0,12,6"
                                       Foreground="White"
                                       Text="{Binding PowerStatus}" />
                            <TextBlock Margin="0,0,12,6"
                                       Foreground="White"
                                       Text="{Binding MotorStatus}" />
                            <TextBlock Margin="0,0,12,6"
                                       Foreground="White"
                                       Text="{Binding TrackingStatus}" />
                            <TextBlock Margin="0,0,12,6"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding ElectronicZoomStatus}" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Margin="0,14,0,0"
                            Padding="12"
                            Background="#FF121923"
                            BorderBrush="#FF27303C"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="White"
                                       Text="밝기" />
                            <DockPanel Margin="0,8,0,0">
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="54"
                                           HorizontalAlignment="Right"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding BrightnessText}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="5"
                            Margin="0,10,0,0"
                            Padding="12"
                            Background="#FF121923"
                            BorderBrush="#FF27303C"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="White"
                                       Text="대조비" />
                            <DockPanel Margin="0,8,0,0">
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Width="54"
                                           HorizontalAlignment="Right"
                                           TextAlignment="Right"
                                           Foreground="{StaticResource AccentBrush}"
                                           Text="{Binding ContrastText}" />
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <ItemsControl Grid.Row="7"
                                  Margin="0,14,0,0"
                                  ItemsSource="{Binding FeatureSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="10"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <TextBlock Foreground="White"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="#FFD3DDE8"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Description}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
