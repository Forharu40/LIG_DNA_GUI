<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI Aerial Tracking Console"
        Width="1800"
        Height="980"
        MinWidth="1500"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="#FF0B1118">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="22" Background="#FF101722" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="White" Text="{Binding MissionTitle}" />
                    <TextBlock Margin="0,8,0,0" Foreground="#FF9FB1C5" Text="{Binding HeaderSummary}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="14,8" Margin="0,0,12,0" Background="#2618C6B0" CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}" Text="{Binding LiveSource}" />
                    </Border>
                    <Border Padding="14,8" Margin="0,0,12,0" Background="#22FFC145" CornerRadius="999">
                        <TextBlock Foreground="{StaticResource WarningBrush}" Text="{Binding PipelineStatus}" />
                    </Border>
                    <Button Padding="18,10" Command="{Binding EmergencyStopCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{StaticResource DangerBrush}" Foreground="{StaticResource DangerBrush}" Content="EMERGENCY STOP" />
                </StackPanel>
            </Grid>
        </Border>

        <ItemsControl Grid.Row="1" Margin="0,16,0,16" ItemsSource="{Binding DetectionMetrics}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,14,0" Padding="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="18">
                        <StackPanel>
                            <TextBlock Foreground="#FF90A4BA" Text="{Binding Label}" />
                            <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="Bold" Foreground="{Binding AccentColor}" Text="{Binding Value}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,16,0" Padding="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="170" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="Live Camera Feed" />
                            <TextBlock Margin="0,4,0,0" Foreground="#FF7F93A8" Text="{Binding SensorReadout}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="#FFB4C1CF" Text="{Binding MissionClock}" />
                    </Grid>

                    <Border Grid.Row="1" Margin="0,16,0,16" Background="#FF080B11" BorderBrush="#FF2E3642" BorderThickness="1" CornerRadius="20">
                        <Grid ClipToBounds="True">
                            <Rectangle Fill="#FF121B26" />
                            <Rectangle Margin="18" RadiusX="18" RadiusY="18" Fill="#FF111A24" Stroke="#FF374250" StrokeThickness="1.5" />
                            <Line X1="90" Y1="60" X2="830" Y2="420" Stroke="#10FFFFFF" StrokeThickness="1" />
                            <Line X1="160" Y1="430" X2="780" Y2="96" Stroke="#11FFFFFF" StrokeThickness="1" />
                            <TextBlock Margin="24,16,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="24" FontWeight="SemiBold" Foreground="White" Text="Ground Defense Console" />
                            <TextBlock Margin="0,18,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#FFCBD8E6" Text="Target Position: North-East" />
                            <TextBlock Margin="0,40,18,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="#FFCBD8E6" Text="Distance: 500m / Tracking mode: aggressive" />
                            <Border Margin="0,0,18,18" HorizontalAlignment="Right" VerticalAlignment="Bottom" Padding="12,6" Background="#3318C6B0" CornerRadius="999">
                                <TextBlock Foreground="{StaticResource AccentBrush}" Text="{Binding LiveSource}" />
                            </Border>

                            <ItemsControl ItemsSource="{Binding Trajectories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas Width="960" Height="540" IsHitTestVisible="False">
                                            <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" Stroke="{Binding StrokeColor}" StrokeThickness="2" />
                                            <Ellipse Width="8" Height="8" Fill="{Binding StrokeColor}" Canvas.Left="{Binding X2}" Canvas.Top="{Binding Y2}" />
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding ActiveDetections}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}" Height="{Binding Height}">
                                            <Border BorderBrush="#FFE44343" BorderThickness="2" CornerRadius="2" Background="#11E44343" />
                                            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,-28,0,0" Padding="8,4" Background="#FFE44343" CornerRadius="6">
                                                <TextBlock Foreground="White" Text="{Binding Tag}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Padding="14" Background="#FF0F151F" BorderBrush="#FF283140" BorderThickness="1" CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="White" Text="On-device Tactical Log" />
                            <ListBox Margin="0,12,0,0" ItemsSource="{Binding AgentLogs}" Background="Transparent" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Width="88" Foreground="{StaticResource WarningBrush}" Text="{Binding Time}" />
                                            <TextBlock Foreground="White" Text="{Binding Message}" TextWrapping="Wrap" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="0,0,16,0" Padding="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="Multiview Cameras" />
                    <ItemsControl Grid.Row="1" Margin="0,16,0,16" ItemsSource="{Binding CameraTiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,12" Padding="10" CornerRadius="16" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#FF101722" />
                                            <Setter Property="BorderBrush" Value="#FF283140" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter Property="Background" Value="#FF152131" />
                                                    <Setter Property="BorderBrush" Value="#FFE44343" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Rectangle RadiusX="12" RadiusY="12" Fill="#FF95A9BF" Opacity="0.18" />
                                        <Rectangle Margin="10" RadiusX="10" RadiusY="10" Fill="#FF6B8AA6" Opacity="0.16" />
                                        <Border Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#CC101722" CornerRadius="8">
                                            <TextBlock Foreground="White" Text="{Binding Title}" />
                                        </Border>
                                        <TextBlock Margin="0,0,0,12" HorizontalAlignment="Center" VerticalAlignment="Bottom" Foreground="#FFD8E1EA" Text="{Binding Subtitle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <UniformGrid Grid.Row="2" Columns="2">
                        <Button Margin="0,0,10,0" Padding="14,12" Command="{Binding SaveSnapshotCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Content="Save Snapshot" />
                        <Button Padding="14,12" Command="{Binding RefreshSummaryCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Content="Refresh LLM Brief" />
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="19" FontWeight="SemiBold" Foreground="White" Text="LLM / VLM Briefing" />
                    <Border Grid.Row="1" Margin="0,14,0,14" Padding="14" Background="#FF161E29" BorderBrush="#FFE44343" BorderThickness="1" CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="#FFFFE1A8" Text="{Binding LlmHeadline}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0" Foreground="#FFD6DEE8" Text="{Binding LlmNarrative}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,12,0,0" Foreground="#FF8AB4FF" Text="{Binding AnalystNote}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White" Text="Recognized Objects and Movement" />
                        <ListBox Grid.Row="1" Margin="0,12,0,12" ItemsSource="{Binding ActiveDetections}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" Background="#FF0D141C" CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="White" Text="{Binding Tag}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#FFD4DEE7" Text="{Binding Classification}" />
                                            <TextBlock Margin="0,2,0,0" Foreground="#FF90A4BA" Text="{Binding MovementSummary}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <ListBox Grid.Row="2" ItemsSource="{Binding RouteSummaries}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="10" Background="#FF0D141C" CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="White" Text="{Binding TargetId}" />
                                            <TextBlock Margin="0,4,0,0" Foreground="#FFD4DEE7" Text="{Binding Note}" />
                                            <TextBlock Margin="0,2,0,0" Foreground="{StaticResource AccentBrush}" Text="{Binding From}" />
                                            <TextBlock Margin="0,2,0,0" Foreground="{StaticResource WarningBrush}" Text="{Binding To}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                    <UniformGrid Grid.Row="3" Margin="0,14,0,0" Columns="2">
                        <Button Margin="0,0,10,0" Padding="14,12" Command="{Binding StartPipelineCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Content="Start Pipeline" />
                        <Button Padding="14,12" Command="{Binding ToggleInferenceCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Content="{Binding InferenceButtonText}" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
