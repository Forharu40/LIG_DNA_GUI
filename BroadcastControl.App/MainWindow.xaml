<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LIG DNA GUI"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D1117">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- 좌측: EO 메인 화면과 IR 인셋 -->
        <Border Grid.Column="0"
                Margin="0,0,12,0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid ClipToBounds="True">
                <Rectangle Fill="#FF111821" />

                <!-- EO 메인 영상 -->
                <Image Source="{Binding EoFeedImage}"
                       Stretch="UniformToFill"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                        ScaleY="{Binding LargeFeedScale}" />
                    </Image.RenderTransform>
                </Image>

                <!-- EO 프레임 경계 -->
                <Rectangle Margin="14"
                           Fill="#10161F2A"
                           Stroke="#FF334050"
                           StrokeThickness="1.5"
                           RadiusX="14"
                           RadiusY="14" />

                <Border Margin="18"
                        Padding="10,6"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="#CC101722"
                        CornerRadius="10">
                    <TextBlock Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               Text="{Binding EoTitle}" />
                </Border>

                <TextBlock Margin="18,0,18,20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Foreground="#FFD5DEE8"
                           FontSize="15"
                           Text="{Binding EoSubtitle}" />

                <!-- IR 인셋 화면 -->
                <Border Width="150"
                        Height="200"
                        Margin="0,18,18,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#FF151920"
                        BorderBrush="#FF334050"
                        BorderThickness="2"
                        CornerRadius="10">
                    <Grid>
                        <Rectangle Margin="10"
                                   Fill="#161E2834"
                                   Stroke="#FF3D4958"
                                   StrokeThickness="1"
                                   RadiusX="10"
                                   RadiusY="10" />
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="{Binding IrTitle}" />
                        <TextBlock Margin="10,0,10,14"
                                   VerticalAlignment="Bottom"
                                   Foreground="#FFC3D0DF"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{Binding IrSubtitle}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- 우측: 상단 정보 패널 + 하단 기능 제어 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.48*" />
                <RowDefinition Height="0.52*" />
            </Grid.RowDefinitions>

            <!-- 우측 상단 -->
            <Grid Grid.Row="0"
                  Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- VLM 출력값 -->
                <Border Grid.Column="0"
                        Margin="0,0,12,0"
                        Padding="14"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Text="VLM 출력값" />
                        <ListBox Grid.Row="1"
                                 Margin="0,14,0,0"
                                 ItemsSource="{Binding VlmResults}"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="#FF121923"
                                            BorderBrush="#FF27303C"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Width="82"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           Text="{Binding Time}" />
                                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                                           Text="{Binding Category}" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding Message}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 우측 상단의 우측 열: 현황 + 변경 로그 -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="0.44*" />
                        <RowDefinition Height="0.56*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,12"
                            Padding="14"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="실시간 시스템 현황" />
                            <Border Margin="0,14,0,0"
                                    Padding="12"
                                    Background="#FF121923"
                                    BorderBrush="#FF27303C"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock Foreground="White" Text="{Binding PowerStatusText}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="White" Text="{Binding CurrentModeStatus}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="White" Text="{Binding CurrentDetectionStatus}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="White" Text="{Binding MotorStatusText}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="White" Text="{Binding TrackingStatusText}" />
                                    <TextBlock Margin="0,8,0,0" Foreground="{StaticResource AccentBrush}" Text="{Binding ElectronicZoomStatus}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Padding="14"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="실시간 시스템 변경 로그" />
                            <ListBox Grid.Row="1"
                                     Margin="0,14,0,0"
                                     ItemsSource="{Binding SystemChangeLogs}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10"
                                                Padding="12"
                                                Background="#FF121923"
                                                BorderBrush="#FF27303C"
                                                BorderThickness="1"
                                                CornerRadius="12">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Width="82"
                                                               Foreground="{StaticResource WarningBrush}"
                                                               Text="{Binding Time}" />
                                                    <TextBlock Foreground="#FF8AB4FF"
                                                               Text="{Binding Category}" />
                                                </DockPanel>
                                                <TextBlock Margin="0,8,0,0"
                                                           Foreground="White"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding Message}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 우측 하단 기능 제어 -->
            <Border Grid.Row="1"
                    Padding="14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- 좌측 제어 열 -->
                    <StackPanel Grid.Column="0"
                                Margin="0,0,10,0">
                        <Button MinHeight="58"
                                Padding="14"
                                Command="{Binding TogglePowerCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Content="시스템 전원 on/off" />

                        <Button Margin="0,12,0,0"
                                MinHeight="58"
                                Padding="14"
                                Command="{Binding CycleModeCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Content="시스템 모드 변경" />

                        <UniformGrid Margin="0,12,0,0"
                                     Columns="3">
                            <Button Margin="0,0,8,0"
                                    MinHeight="54"
                                    Padding="10"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="기체 고정"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Content="기체 고정" />
                            <Button Margin="0,0,8,0"
                                    MinHeight="54"
                                    Padding="10"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="수동"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Content="수동" />
                            <Button MinHeight="54"
                                    Padding="10"
                                    Command="{Binding SelectModeCommand}"
                                    CommandParameter="추적"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="15"
                                    FontWeight="SemiBold"
                                    Content="추적" />
                        </UniformGrid>

                        <Button Margin="0,16,0,0"
                                MinHeight="58"
                                Padding="14"
                                Command="{Binding ToggleElectronicZoomCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Content="ZOOM" />

                        <UniformGrid Margin="0,12,0,0"
                                     Columns="2">
                            <Button Margin="0,0,8,0"
                                    MinHeight="54"
                                    Padding="10"
                                    Command="{Binding DecreaseZoomCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="ZOOM -" />
                            <Button MinHeight="54"
                                    Padding="10"
                                    Command="{Binding IncreaseZoomCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="ZOOM +" />
                        </UniformGrid>
                    </StackPanel>

                    <!-- 우측 제어 열 -->
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0">
                        <UniformGrid Columns="2">
                            <Button Margin="0,0,8,0"
                                    MinHeight="58"
                                    Padding="14"
                                    Command="{Binding ToggleMotorCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="모터 on/off" />
                            <Button MinHeight="58"
                                    Padding="14"
                                    Command="{Binding ToggleTrackingCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="17"
                                    FontWeight="SemiBold"
                                    Content="트래킹 on/off" />
                        </UniformGrid>

                        <Button Margin="0,12,0,0"
                                MinHeight="58"
                                Padding="14"
                                Command="{Binding CycleDetectionCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="17"
                                FontWeight="SemiBold"
                                Content="탐지체 변경" />

                        <Button Margin="0,12,0,0"
                                MinHeight="52"
                                Padding="12"
                                Command="{Binding SelectDetectionCategoryCommand}"
                                CommandParameter="복합"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Content="복합" />

                        <UniformGrid Margin="0,10,0,0"
                                     Columns="2">
                            <Button Margin="0,0,8,0"
                                    MinHeight="52"
                                    Padding="12"
                                    Command="{Binding SelectDetectionCategoryCommand}"
                                    CommandParameter="고정익"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="고정익" />
                            <Button MinHeight="52"
                                    Padding="12"
                                    Command="{Binding SelectDetectionCategoryCommand}"
                                    CommandParameter="회전익"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="회전익" />
                        </UniformGrid>

                        <UniformGrid Margin="0,10,0,0"
                                     Columns="2">
                            <Button Margin="0,0,8,0"
                                    MinHeight="52"
                                    Padding="12"
                                    Command="{Binding SelectDetectionCategoryCommand}"
                                    CommandParameter="드론"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="드론" />
                            <Button MinHeight="52"
                                    Padding="12"
                                    Command="{Binding SelectDetectionCategoryCommand}"
                                    CommandParameter="사람"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Content="사람" />
                        </UniformGrid>

                        <Border Margin="0,14,0,0"
                                Padding="12"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="White"
                                           Text="{Binding BrightnessText}" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,10,0,0"
                                Padding="12"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="White"
                                           Text="{Binding ContrastText}" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
