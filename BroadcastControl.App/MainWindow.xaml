<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LIG DNA GUI"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#FF0D1117">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <!-- 상단 듀얼 화면: 좌측 큰 화면 3/4, 중앙 스왑 버튼, 우측 작은 화면 1/4 -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="82" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측 큰 화면: 현재는 EO 노트북 카메라 영상을 출력한다 -->
            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ClipToBounds="True">
                    <Rectangle Fill="#FF111821" />

                    <!-- 전자 줌은 영상 자체에만 적용해서 화면 틀은 커지지 않게 한다 -->
                    <Image Source="{Binding PrimaryFeedImage}"
                           Stretch="UniformToFill"
                           RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                            ScaleY="{Binding LargeFeedScale}" />
                        </Image.RenderTransform>
                    </Image>

                    <!-- 카메라 영상이 없는 경우에도 기본 틀은 유지한다 -->
                    <Rectangle Margin="16"
                               Fill="#10161F2A"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />

                    <Border Margin="18"
                            Padding="10,6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding LargeFeedTitle}" />
                    </Border>

                    <TextBlock Margin="18,0,18,18"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="16"
                               Text="{Binding LargeFeedSubtitle}" />

                    <!-- 향후 detector / tracker 결과를 이 레이어에 빨간 박스로 그리면 된다 -->
                    <Canvas IsHitTestVisible="False" />

                    <Border Margin="0,0,18,18"
                            Padding="12,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#3318C6B0"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding ElectronicZoomStatus}" />
                    </Border>
                </Grid>
            </Border>

            <!-- 중앙 스왑 버튼 -->
            <Grid Grid.Column="1">
                <Button Width="62"
                        Height="90"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Command="{Binding SwapFeedsCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        FontSize="22"
                        FontWeight="Bold"
                        Content="&#8646;" />
            </Grid>

            <!-- 우측 작은 화면: 현재는 IR 자리 표시 영역 -->
            <Border Grid.Column="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ClipToBounds="True">
                    <Rectangle Fill="#FF151920" />

                    <Image Source="{Binding SecondaryFeedImage}"
                           Stretch="UniformToFill" />

                    <Rectangle Margin="16"
                               Fill="#10161F2A"
                               Stroke="#FF334050"
                               StrokeThickness="1.5"
                               RadiusX="16"
                               RadiusY="16" />

                    <Border Margin="18"
                            Padding="8,5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="#CC101722"
                            CornerRadius="10">
                        <TextBlock FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="{Binding SmallFeedTitle}" />
                    </Border>

                    <TextBlock Margin="18,0,18,18"
                               VerticalAlignment="Bottom"
                               Foreground="#FFD4DEE8"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Text="{Binding SmallFeedSubtitle}" />

                    <!-- 작은 화면도 같은 방식의 오버레이 레이어를 추가할 수 있게 자리를 남겨둔다 -->
                    <Canvas IsHitTestVisible="False" />
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 3분할: VLM 결과, 시스템 로그, 기능 제어 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 좌측: VLM 결과 출력창 -->
            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="VLM 결과값 출력창" />
                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding VlmResults}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Width="82"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Text="{Binding Time}" />
                                            <TextBlock Foreground="{StaticResource AccentBrush}"
                                                       Text="{Binding Category}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Message}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 중앙: 실시간 시스템 로그 -->
            <Border Grid.Column="1"
                    Margin="12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="실시간 시스템 로그" />

                    <ListBox Grid.Row="1"
                             Margin="0,14,0,0"
                             ItemsSource="{Binding SystemLogs}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="#FF121923"
                                        BorderBrush="#FF27303C"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Width="82"
                                                       Foreground="{StaticResource WarningBrush}"
                                                       Text="{Binding Time}" />
                                            <TextBlock Foreground="#FF8AB4FF"
                                                       Text="{Binding Category}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="White"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Message}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 우측: 기능 제어 버튼 -->
            <Border Grid.Column="2"
                    Margin="12,0,0,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="기능 제어" />

                        <!-- 모드 제어 -->
                        <Border Margin="0,14,0,0"
                                Padding="14"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="#FFB9C7D7"
                                           Text="모드" />
                                <Button Margin="0,10,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding CycleModeCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="모드 변경" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding CurrentModeStatus}" />
                            </StackPanel>
                        </Border>

                        <!-- 탐지 제어 -->
                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="#FFB9C7D7"
                                           Text="탐지" />
                                <Button Margin="0,10,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding CycleDetectionCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="탐지 변경" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding CurrentDetectionStatus}" />
                            </StackPanel>
                        </Border>

                        <!-- 전원과 줌 제어 -->
                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="#FFB9C7D7"
                                           Text="전원 / Zoom" />
                                <Button Margin="0,10,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding TogglePowerCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="On / Off" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding PowerStatusText}" />

                                <Button Margin="0,14,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding ToggleElectronicZoomCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="전자 Zoom" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding ElectronicZoomStatus}" />

                                <UniformGrid Margin="0,12,0,0"
                                             Columns="2">
                                    <Button Margin="0,0,8,0"
                                            MinHeight="56"
                                            Padding="12"
                                            Command="{Binding IncreaseZoomCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Content="Zoom +" />
                                    <Button Margin="8,0,0,0"
                                            MinHeight="56"
                                            Padding="12"
                                            Command="{Binding DecreaseZoomCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Content="Zoom -" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- 구동과 추적 제어 -->
                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="#FFB9C7D7"
                                           Text="구동 / 추적" />
                                <Button Margin="0,10,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding ToggleMotorCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="Motor 제어" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding MotorStatusText}" />

                                <Button Margin="0,14,0,0"
                                        MinHeight="64"
                                        Padding="16"
                                        Command="{Binding ToggleTrackingCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Content="Tracking 제어" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding TrackingStatusText}" />
                            </StackPanel>
                        </Border>

                        <!-- 영상 보정 -->
                        <Border Margin="0,12,0,0"
                                Padding="14"
                                Background="#FF121923"
                                BorderBrush="#FF27303C"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Foreground="#FFB9C7D7"
                                           Text="밝기 / 대조비" />
                                <TextBlock Margin="0,10,0,0"
                                           Foreground="White"
                                           Text="{Binding BrightnessText}" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Margin="0,12,0,0"
                                           Foreground="White"
                                           Text="{Binding ContrastText}" />
                                <Slider Margin="0,8,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>

                        <Button Margin="0,14,0,0"
                                MinHeight="64"
                                Padding="16"
                                Command="{Binding EmergencyStopCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{StaticResource DangerBrush}"
                                Foreground="{StaticResource DangerBrush}"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Content="비상 정지" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
