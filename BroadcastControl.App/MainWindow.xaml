<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="LIG DNA GUI"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DropShadowEffect x:Key="SoftPanelShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="TopBarShadow"
                          BlurRadius="6"
                          ShadowDepth="0"
                          Direction="270"
                          Opacity="0.12"
                          Color="#66000000" />

        <DropShadowEffect x:Key="DrawerShadow"
                          BlurRadius="10"
                          ShadowDepth="1"
                          Direction="270"
                          Opacity="0.10"
                          Color="#66000000" />

        <Style x:Key="GlassCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Effect" Value="{StaticResource SoftPanelShadow}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="OverlayCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>

        <Style x:Key="TopBarButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarSmallButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource TopBarButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TopBarButtonPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopBarCompactSlider" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ArrowButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Opacity" Value="0.9" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource OverlayPanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="MotorPadButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#33475663" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#55475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#66475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InlineRotateButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#33475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaybackIconButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#22313A46" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33475663" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#55475663" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SettingsActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource DrawerItemBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DrawerItemBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DrawerTextBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="2" />
        </Style>

        <Style x:Key="ZoomSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="14" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="0.72" ScaleY="0.72" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
    <Grid x:Name="RootLayout"
          Width="1600"
          Height="900">
        <!-- ?꾩껜 李?理쒖긽??而⑦뀒?대꼫??
             ?곷떒 ?대컮, 蹂몃Ц ?⑤꼸, ?ㅼ젙 ?쒕줈?대? ??Grid ?덉뿉 諛곗튂 -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="0" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="2"
                       Margin="-4"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <DynamicResource ResourceKey="WindowBackdropBrush" />
                </Rectangle.Fill>
            </Rectangle>

            <!-- ?곷떒 ?대컮:
                 ?꾩썝 醫낅즺, ?뱁솕 ?곹깭, 諛앷린/?議곕퉬, 紐⑤뱶 ?꾪솚, ?ㅼ젙 踰꾪듉 諛곗튂 -->
            <Border Grid.Row="0"
                    Visibility="Collapsed"
                    Style="{StaticResource GlassCardBorder}"
                    CornerRadius="2"
                    Effect="{StaticResource TopBarShadow}">
                <Grid Margin="14,10,42,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="152" />
                        <ColumnDefinition Width="152" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="96" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            MinWidth="126"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource TopBarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="16"
                                     Height="16"
                                     Margin="0,0,8,0"
                                     Fill="{Binding CurrentThreatBrush}" />
                            <TextBlock Text="{Binding PowerButtonText}" />
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Opacity="{Binding RecordingIndicatorOpacity}">
                        <Ellipse Width="12"
                                 Height="12"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding RecordingIndicatorBrush}" />
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="{Binding RecordingTextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="&#xC601;&#xC0C1; &#xB179;&#xD654; &#xC911;" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                        <Button HorizontalAlignment="Left"
                                Command="{Binding ResetBrightnessCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding BrightnessText}" />
                        <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center">
                        <Button HorizontalAlignment="Left"
                                Command="{Binding ResetContrastCommand}"
                                Style="{StaticResource TopBarSmallButton}"
                                Content="{Binding ContrastText}" />
                        <Slider Margin="0,2,0,0"
                                Minimum="0"
                                Maximum="100"
                                Style="{StaticResource TopBarCompactSlider}"
                                Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsSystemPoweredOn}" />
                    </StackPanel>

                    <Button Grid.Column="4"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="&#xC790;&#xB3D9;"
                            IsHitTestVisible="{Binding CanSelectAutoMode}"
                            Opacity="{Binding AutoModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="&#xC790;&#xB3D9;" />

                    <Button Grid.Column="5"
                            Margin="0,0,8,0"
                            Width="92"
                            Command="{Binding SetModeCommand}"
                            CommandParameter="&#xC218;&#xB3D9;"
                            IsHitTestVisible="{Binding CanSelectManualMode}"
                            Opacity="{Binding ManualModeOpacity}"
                            Style="{StaticResource TopBarButton}"
                            Content="&#xC218;&#xB3D9;" />

                    <Button Grid.Column="6"
                            Width="84"
                            Margin="0,0,12,0"
                            Padding="10,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Style="{StaticResource TopBarSmallButton}"
                            Opacity="{Binding ManualRecordingButtonOpacity}"
                            IsEnabled="{Binding IsManualMode}"
                            Command="{Binding ToggleManualRecordingCommand}"
                            Content="{Binding ManualRecordingButtonText}" />

                    <Button Grid.Column="7"
                            Width="54"
                            Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource TopBarButton}">
                        <materialDesign:PackIcon Kind="Menu"
                                                 Width="24"
                                                 Height="24" />
                    </Button>
                </Grid>
            </Border>

            <!-- 蹂몃Ц ?곸뿭:
                 ?쇱そ 移대찓???붾㈃, ?ㅻⅨ履??쒖뒪???꾪솴/?곹솴 遺꾩꽍/?쒖뒪??濡쒓렇 ?⑤꼸 -->
            <Grid Grid.Row="1"
                  Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="74" />
                        <RowDefinition Height="150" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
                            Margin="0,0,0,12"
                            Command="{Binding TogglePowerCommand}"
                            Style="{StaticResource TopBarButton}">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding PowerButtonText}" />
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="8,1,0,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding CurrentThreatBrush}" />
                        </StackPanel>
                    </Button>

                    <Border Grid.Row="1"
                            Margin="0,0,0,12"
                            Style="{StaticResource GlassCardBorder}"
                            Background="#FF05070A">
                        <Grid Margin="12">
                            <Border Width="108"
                                    Height="25"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource OverlayCardBorder}"
                                    BorderThickness="0"
                                    Padding="7,3">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="CAM 1"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="12"
                                               FontWeight="Bold" />
                                    <Button DockPanel.Dock="Right"
                                            Margin="8,0,0,0"
                                            Tag="CAM 1"
                                            Click="RotateAuxCameraButton_OnClick"
                                            Style="{StaticResource InlineRotateButton}">
                                        <materialDesign:PackIcon Kind="RotateRight" Width="12" Height="12" />
                                    </Button>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource GlassCardBorder}"
                            Background="#FF05070A">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Text="Motor Info" />
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Margin="0,0,4,0"
                                        Padding="6"
                                        Background="#12000000"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Text="Pan Motor" />
                                        <ItemsControl Grid.Row="1"
                                                      Margin="0,6,0,0"
                                                      ItemsSource="{Binding PanMotorStatusItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,4"
                                                            Padding="5,3"
                                                            Background="#22313A46"
                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <StackPanel>
                                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       LineHeight="10"
                                                                       Text="{Binding Name}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,1,0,0"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       LineHeight="13"
                                                                       Text="{Binding Value}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1"
                                        Margin="4,0,0,0"
                                        Padding="6"
                                        Background="#12000000"
                                        BorderBrush="{DynamicResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Text="Tilt Motor" />
                                        <ItemsControl Grid.Row="1"
                                                      Margin="0,6,0,0"
                                                      ItemsSource="{Binding TiltMotorStatusItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,4"
                                                            Padding="5,3"
                                                            Background="#22313A46"
                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                        <StackPanel>
                                                            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       LineHeight="10"
                                                                       Text="{Binding Name}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Margin="0,1,0,0"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       LineHeight="13"
                                                                       Text="{Binding Value}"
                                                                       TextWrapping="Wrap" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 移대찓???⑤꼸:
                     EO 二??붾㈃, IR ?몄뀑 ?붾㈃, 紐⑦꽣 議곗옉 踰꾪듉, ?꾩옄 以?UI瑜??ы븿?? -->
                <Grid Grid.Column="1"
                      Margin="0,0,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="150" />
                    </Grid.RowDefinitions>

                <Border x:Name="CameraPanel"
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        Style="{StaticResource GlassCardBorder}"
                        BorderBrush="#00000000"
                        CornerRadius="2">
                    <Grid x:Name="CameraViewport"
                          ClipToBounds="True"
                          SizeChanged="CameraViewport_OnSizeChanged"
                          MouseLeftButtonDown="CameraViewport_OnMouseLeftButtonDown"
                          MouseWheel="CameraViewport_OnMouseWheel"
                          MouseMove="CameraViewport_OnMouseMove"
                          MouseLeftButtonUp="CameraViewport_OnMouseLeftButtonUp">
                        <Rectangle Fill="{DynamicResource SurfaceAltBrush}" />

                        <!-- LargeFeedImage???ш쾶 蹂댁뿬以?移대찓???곸긽 諛붿씤?⑹엫.
                             EO/IR ?ㅼ솑 ?곹깭???곕씪 ?쒖떆 ?곸긽???щ씪吏? -->
                        <Image Source="{Binding LargeFeedImage}"
                               Margin="0"
                               Stretch="{Binding LargeFeedStretch}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding LargeFeedRotationAngle}" />
                                    <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                                    ScaleY="{Binding LargeFeedScale}" />
                                    <TranslateTransform X="{Binding ZoomTransformX}"
                                                        Y="{Binding ZoomTransformY}" />
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>

                        <!-- 醫뚯긽???쇰꺼? ?꾩옱 ???붾㈃??移대찓??醫낅쪟 ?쒖떆?? -->
                        <Border Margin="16,12,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Style="{StaticResource OverlayCardBorder}"
                                BorderThickness="0"
                                CornerRadius="2"
                                Padding="8,4">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           Text="{Binding LargeFeedTitle}" />
                                <Button DockPanel.Dock="Right"
                                        Margin="10,0,0,0"
                                        Click="RotateLargeFeedButton_OnClick"
                                        Style="{StaticResource InlineRotateButton}">
                                    <materialDesign:PackIcon Kind="RotateRight" Width="14" Height="14" />
                                </Button>
                            </DockPanel>
                        </Border>

                        <!-- ?꾩옄 以?誘몃땲留?
                             ?뺣? 以??꾩껜 ?붾㈃ ?鍮??꾩옱 蹂닿퀬 ?덈뒗 ?곸뿭???묒? 吏?꾩쿂???쒖떆?? -->
                        <Border Width="152"
                                Height="108"
                                Margin="18,0,0,20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource OverlayCardBorder}"
                                CornerRadius="2"
                                Visibility="{Binding ShowZoomMiniMap, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="10">
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11"
                                           Text="Zoom &#xBBF8;&#xB2C8;&#xB9F5;" />
                                <Canvas Width="130"
                                        Height="74"
                                        Margin="0,18,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top">
                                    <Rectangle Width="130"
                                               Height="74"
                                               Fill="#55333F4D"
                                               Stroke="#FF64748B"
                                               StrokeThickness="1" />
                                    <Rectangle Width="{Binding MiniMapViewportWidth}"
                                               Height="{Binding MiniMapViewportHeight}"
                                               Canvas.Left="{Binding MiniMapViewportLeft}"
                                               Canvas.Top="{Binding MiniMapViewportTop}"
                                               Fill="#3300FFAA"
                                               Stroke="{DynamicResource AccentBrush}"
                                               StrokeThickness="1.5" />
                                </Canvas>
                            </Grid>
                        </Border>

                        <Canvas x:Name="DetectionOverlayCanvas"
                                Width="{Binding ElementName=CameraViewport, Path=ActualWidth}"
                                Height="{Binding ElementName=CameraViewport, Path=ActualHeight}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Panel.ZIndex="5"
                                ClipToBounds="True"
                                RenderTransformOrigin="0.5,0.5"
                                IsHitTestVisible="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="{Binding LargeFeedScale}"
                                                    ScaleY="{Binding LargeFeedScale}" />
                                    <TranslateTransform X="{Binding ZoomTransformX}"
