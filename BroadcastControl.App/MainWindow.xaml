<Window x:Class="BroadcastControl.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LIG DNA GUI"
        Width="1600"
        Height="950"
        MinWidth="1320"
        MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="#FF0E1117">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="18"
                Margin="0,0,0,16"
                Background="#FF101722"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding MissionTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FF9FB1C5"
                               Text="{Binding HeaderSummary}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Padding="12,6"
                            Margin="0,0,12,0"
                            Background="#2618C6B0"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   Text="{Binding LiveSource}" />
                    </Border>
                    <Border Padding="12,6"
                            Background="#22FFC145"
                            CornerRadius="999">
                        <TextBlock Foreground="{StaticResource WarningBrush}"
                                   Text="{Binding PipelineStatus}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.7*" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.15*" />
                    <RowDefinition Height="0.85*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,10,10"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="#FF1F1F1F"
                            BorderThickness="3">
                        <Grid>
                            <Rectangle Margin="12"
                                       Fill="#FF161D27"
                                       Stroke="#FF303B4B"
                                       StrokeThickness="1.5" />
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="{Binding EOFeedLabel}" />
                            <TextBlock Margin="16"
                                       VerticalAlignment="Bottom"
                                       Foreground="#FFB1C0D2"
                                       Text="{Binding EOFeedSummary}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            Margin="10,0,0,10"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="#FF1F1F1F"
                            BorderThickness="3">
                        <Grid>
                            <Rectangle Margin="12"
                                       Fill="#FF171A20"
                                       Stroke="#FF303B4B"
                                       StrokeThickness="1.5" />
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="{Binding IRFeedLabel}" />
                            <TextBlock Margin="16"
                                       VerticalAlignment="Bottom"
                                       Foreground="#FFB1C0D2"
                                       Text="{Binding IRFeedSummary}" />
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.3*" />
                        <ColumnDefinition Width="0.95*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,10,10,0"
                            Padding="18"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="#FF1F1F1F"
                            BorderThickness="3">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Text="{Binding ControlPanelTitle}" />
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,14"
                                       Foreground="#FFB1C0D2"
                                       Text="{Binding ControlPanelSummary}" />

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Text="{Binding CurrentTarget}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="#FFD7E0EA"
                                               Text="{Binding TrackingStatus}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#FFD7E0EA"
                                               Text="{Binding ModeName}" />
                                </StackPanel>

                                <ListBox Grid.Row="1"
                                         Margin="0,18,0,0"
                                         ItemsSource="{Binding ControlLogs}"
                                         Background="Transparent"
                                         BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel Margin="0,0,0,8">
                                                <TextBlock Width="86"
                                                           Foreground="{StaticResource WarningBrush}"
                                                           Text="{Binding Time}" />
                                                <TextBlock Foreground="White"
                                                           Text="{Binding Message}"
                                                           TextWrapping="Wrap" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1"
                          Margin="10,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Margin="0,0,0,10"
                                Padding="10"
                                Command="{Binding StartPipelineCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Content="{Binding PowerButtonLabel}" />
                        <Button Grid.Row="1"
                                Margin="0,0,0,10"
                                Padding="10"
                                Command="{Binding ToggleInferenceCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="{Binding TrackingButtonLabel}" />
                        <Button Grid.Row="2"
                                Padding="10"
                                Command="{Binding RefreshSummaryCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="{Binding ModeButtonLabel}" />
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="18"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#FF1F1F1F"
                    BorderThickness="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               Text="기능 패널" />

                    <ItemsControl Grid.Row="1"
                                  Margin="0,18,0,18"
                                  ItemsSource="{Binding OtherFunctions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12"
                                        Padding="14"
                                        Background="#FF141B25"
                                        BorderBrush="#FF283140"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   Text="{Binding Title}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#FFD0DBE7"
                                                   Text="{Binding Description}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <UniformGrid Grid.Row="2"
                                 Columns="2">
                        <Button Margin="0,0,10,0"
                                Padding="12"
                                Command="{Binding SaveSnapshotCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Content="Snapshot" />
                        <Button Padding="12"
                                Command="{Binding EmergencyStopCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{StaticResource DangerBrush}"
                                Foreground="{StaticResource DangerBrush}"
                                Content="Emergency" />
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
